@page
@model RazorPagesAutomobile.Pages_Automobile.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>

<form>
    <p>
        <select asp-for="Automobile" asp-items="Model.Make">
            <option value="">All</option>
        </select>
        <label>Model: <input type="text" asp-for="SearchString" /></label>
        <input type="submit" value="Filter" />
    </p>
</form>


<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Automobile[0].Make)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Automobile[0].Model)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Automobile[0].Bodystyle)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Automobile[0].ReleaseDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Automobile[0].MSRP)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Automobile) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Make)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Model)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Bodystyle)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReleaseDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MSRP)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
